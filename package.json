{
  "name": "echo",
  "version": "0.1.0",
  "description": "Echo - On-device AI voice assistant for high-achievers. Record, transcribe, extract action items, and sync across apps.",
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "postinstall": "node scripts/fix-expo-dev-menu.js",
    "prebuild": "expo prebuild",
    "dev:ios": "expo run:ios",
    "dev:android": "expo run:android",
    "test": "jest",
    "eject": "expo eject"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^1.21.0",
    "expo": "^50.0.0",
    "expo-av": "^13.10.5",
    "expo-calendar": "~12.2.1",
    "expo-clipboard": "~6.0.3",
    "expo-dev-client": "~3.3.12",
    "expo-file-system": "~16.0.9",
    "expo-location": "~16.5.5",
    "expo-speech": "^11.5.0",
    "expo-speech-recognition": "^0.0.26",
    "react": "18.2.0",
    "react-dom": "^18.2.0",
    "react-native": "0.73.6",
    "react-native-purchases": "^9.15.0",
    "react-native-uuid": "^2.0.1",
    "react-native-web": "^0.19.10"
  },
  "devDependencies": {
    "@babel/core": "^7.23.0",
    "@types/jest": "^30.0.0",
    "@types/react": "^18.2.0",
    "@types/react-native": "^0.73.0",
    "jest": "^29.7.0",
    "jest-expo": "~50.0.4",
    "typescript": "^5.2.0"
  },
  "jest": {
    "preset": "jest-expo"
  }
